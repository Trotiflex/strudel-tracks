let bridge = note("~@9.5 c4@0.25 bb3@0.25 c4@0.5 d4@0.25 eb4@0.75 c4@0.25 eb4@0.75 f4@0.25 d4@0.75 c4@0.25 d4@1 c4@0.25 eb4@0.5 d4@0.5 bb3@0.5 bb3@0.25 c4@0.5 ~@0.25 c4@0.25 bb3@0.25 c4@0.5 d4@0.25 eb4@0.75 bb3@0.25 eb4@0.75 f4@0.25 d4@0.75 c4@0.25 d4@0.5 eb4@0.25 eb4@0.5 d4@0.5 bb3@0.5 bb3@0.25 c4@0.75 c4@0.25 c4@0.25 c4@0.25 d4@0.5 eb4@0.75 g4@0.25 g4@0.25 f4@0.5 eb4@0.25 f4@0.75 g4@0.25 f4@0.5 ~@0.5 f4@0.25 g4@0.5 g4@0.5 g4@0.5 f4@0.25 g4@0.25").s("piano").slow(10)

