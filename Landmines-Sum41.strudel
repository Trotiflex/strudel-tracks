$: arrange(
  [10.5, stack(verse, verseChords)],
  [8.5, stack(chorus, chorusChords)],
  [4, stack(leadOut, leadOutChords)],
  [10, stack(bridge, bridgeChords)],
  [8.5, stack(chorus, chorusChords)]
)._punchcard()